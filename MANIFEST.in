recursive-include cmake         *.cmake
recursive-include data          *.tsv *.pl *.txt
recursive-include doc           *.md
recursive-include python        *.py *.model *.txt *.i *.sh *.ipynb *.md *.cxx
recursive-include src           *.cc *.h *.txt *.proto
recursive-include third_party   LICENSE *.inc *.txt *.cc *.h *.hxx *.proto

include LICENSE README.md
include config.h.in
include sentencepiece.pc.in
include taskfile.yaml
include uv.lock
include pyproject.toml
include CMakeLists.txt
include VERSION.txt
include build_bundled.sh
include build_sdist.sh

global-exclude */__pycache__/*
global-exclude *.pyc
